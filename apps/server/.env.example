# 青投供应链 V6 后端环境变量配置
# 复制此文件为 .env 并填写真实值

# 数据库连接（必填）
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@127.0.0.1:5432/qingtou_v6

# JWT 密钥（必填，生产环境必须修改为强随机字符串）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace-with-your-secure-jwt-secret-here

# 测试数据库连接（可选，默认使用开发数据库的凭据）
# TEST_DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@127.0.0.1:5432/qingtou_v6_test
# TEST_DB_ADMIN_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@127.0.0.1:5432/postgres

# CORS 跨域配置（可选，默认允许 localhost:9527/9528）
# 生产环境需要添加实际域名，多个域名用逗号分隔
# CORS_ORIGINS=["http://localhost:9527","http://localhost:9528","https://your-domain.com"]
